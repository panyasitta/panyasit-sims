            </div>

            <!-- ฝั่งขวา: แผงควบคุมตามแท็บ -->
            <div class="w-full lg:w-[420px] flex flex-col gap-4 relative min-h-[600px]">
                
                <!-- ================== แท็บ 1: โหมด Demo ================== -->
                <div id="panel-demo" class="bg-white p-4 rounded-xl shadow border border-gray-100 flex flex-col gap-3 absolute inset-0 overflow-y-auto">
                    <div class="flex items-center justify-between border-b pb-2">
