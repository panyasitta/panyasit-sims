        function resetDrawing() {
            userDistancePoints = []; userDisplacement = { start: null, end: null };
            document.getElementById('draw-dist-display').innerHTML = `0.0 <span class="text-xs font-normal">ม.</span>`;
            document.getElementById('draw-disp-display').innerHTML = `0.0 <span class="text-xs font-normal">ม.</span>`;
