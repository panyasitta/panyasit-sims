        function undoLastPoint() {
            if (currentDrawTool === 'distance' && userDistancePoints.length > 0) userDistancePoints.pop();
            else userDisplacement = { start: null, end: null };
            updateDrawingSimulation();
        }

        function updateDrawingSimulation() {
            drawSimulationMap();
            let dDist = 0, dDisp = 0;

            if (userDistancePoints.length > 0) {
                ctx.beginPath(); ctx.moveTo(userDistancePoints[0].px, userDistancePoints[0].py);
                ctx.strokeStyle = 'rgba(37, 99, 235, 0.75)'; ctx.lineWidth = 5; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
                for (let i = 1; i < userDistancePoints.length; i++) {
                    ctx.lineTo(userDistancePoints[i].px, userDistancePoints[i].py);
                    dDist += Math.hypot(userDistancePoints[i].gridX - userDistancePoints[i-1].gridX, userDistancePoints[i].gridY - userDistancePoints[i-1].gridY);
                }
                ctx.stroke();
                userDistancePoints.forEach(pt => { ctx.fillStyle = '#1d4ed8'; ctx.beginPath(); ctx.arc(pt.px, pt.py, 4, 0, Math.PI * 2); ctx.fill(); });
            }

            if (userDisplacement.start) {
                const s = userDisplacement.start;
                ctx.fillStyle = '#dc2626'; ctx.beginPath(); ctx.arc(s.px, s.py, 6, 0, Math.PI * 2); ctx.fill();
                if (userDisplacement.end) {
                    const e = userDisplacement.end;
                    ctx.beginPath(); ctx.moveTo(s.px, s.py); ctx.lineTo(e.px, e.py);
                    ctx.strokeStyle = '#dc2626'; ctx.lineWidth = 3; ctx.setLineDash([8, 6]); ctx.stroke(); ctx.setLineDash([]);
                    drawVectorArrow(s.px, s.py, e.px, e.py, '#dc2626');
                    dDisp = Math.hypot(e.gridX - s.gridX, e.gridY - s.gridY);
                }
            }

            document.getElementById('draw-dist-display').innerHTML = `${(dDist * scaleMeters).toFixed(1)} <span class="text-xs font-normal">ม.</span>`;
            document.getElementById('draw-disp-display').innerHTML = `${(dDisp * scaleMeters).toFixed(1)} <span class="text-xs font-normal">ม.</span>`;
        }

        // --- ระบบตรวจจับ Input ---
        canvas.addEventListener('mousemove', (e) => {
            const rect = canvas.getBoundingClientRect();
            const gX = Math.round((e.clientX - rect.left - originX) / gridSize);
            const gY = Math.round((originY - (e.clientY - rect.top)) / gridSize);
            document.getElementById('coordinate-tracker').innerText = (gX >= 0 && gX <= 5 && gY >= 0 && gY <= 5) ? `พิกัดปัจจุบัน: (X: ${gX * 10}ม., Y: ${gY * 10}ม.)` : `พิกัดเมาส์: นอกเขต`;
        });

        canvas.addEventListener('mousedown', (e) => handleCanvasInput(e.clientX, e.clientY));
        canvas.addEventListener('touchstart', (e) => { if (e.touches.length > 0) { handleCanvasInput(e.touches[0].clientX, e.touches[0].clientY); e.preventDefault(); } });

        function handleCanvasInput(cX, cY) {
            if (activeTab !== 'draw') return;
            const rect = canvas.getBoundingClientRect(), mX = cX - rect.left, mY = cY - rect.top;
            
            let snapPt = null;
            for (let key in locations) {
                const pt = locations[key], pX = getScreenX(pt.x), pY = getScreenY(pt.y);
                if (Math.hypot(pX - mX, pY - mY) < 35) { snapPt = { gridX: pt.x, gridY: pt.y, px: pX, py: pY }; break; }
            }
            if (!snapPt) {
                const tX = Math.round((mX - originX) / gridSize), tY = Math.round((originY - mY) / gridSize);
                if (tX >= 0 && tX <= 6 && tY >= 0 && tY <= 6) snapPt = { gridX: tX, gridY: tY, px: getScreenX(tX), py: getScreenY(tY) };
            }
            if (!snapPt) return;

            if (currentDrawTool === 'distance') {
                if (userDistancePoints.length > 0) {
                    const l = userDistancePoints[userDistancePoints.length - 1];
                    if (l.gridX === snapPt.gridX && l.gridY === snapPt.gridY) return;
                }
                userDistancePoints.push(snapPt);
            } else {
                if (!userDisplacement.start) userDisplacement.start = snapPt;
                else userDisplacement.end = snapPt;
            }
            updateDrawingSimulation();
        }

