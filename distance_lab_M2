    <script>
        // --- ตัวแปรหลักและการตั้งค่า Canvas ---
        const canvas = document.getElementById('simCanvas');
        const ctx = canvas.getContext('2d');
        const gridSize = 45; 
        const scaleMeters = 10; 
        const originX = 150; 
        const originY = 380;

        const locations = {
            A: { x: 0, y: 0, label: "A", emoji: "🚶‍♂️" },
            B: { x: 2, y: 0, label: "B", emoji: "📮" },
            C: { x: 5, y: 0, label: "C", emoji: "🚌" },
            D: { x: 5, y: 5, label: "D", emoji: "🏫" },
            E: { x: 0, y: 5, label: "E", emoji: "🚦" }
        };

        // สถานะแอพพลิเคชัน
        let activeTab = 'demo'; 
        let playbackSpeed = 1.0; 
        
        // สถานะ Demo
        let animProgress = 0;
        let animFrameId = null;
        let animSegments = [];
        let animTotalUnits = 0;

        // สถานะ Draw
        let currentDrawTool = 'distance'; 
        let userDistancePoints = []; 
        let userDisplacement = { start: null, end: null }; 

        // ข้อมูลโจทย์ 2.1 - 2.5
        const scenarios = {
            1: { path: [locations.A, locations.B], desc: "<b>กิตติเดินจาก A ไป B:</b> ระยะทางและการกระจัดเท่ากัน (20 ม.) เพราะเคลื่อนที่เป็นเส้นตรงไม่เปลี่ยนทิศทาง" },
            2: { path: [locations.A, locations.C, locations.B], desc: "<b>จาก A ไป C แล้วย้อนกลับ B:</b> <br>ระยะทาง = 80 ม. แต่การกระจัด = 20 ม. (ทิศตะวันออก)" },
            3: { path: [locations.A, locations.C, locations.D], desc: "<b>จาก A ไป C แล้วไป D:</b><br>ระยะทาง = 100 ม. <br>การกระจัด (เส้นตรง A->D) ≈ 70.7 เมตร" },
            4: { path: [locations.A, locations.D], desc: "<b>เดินลัดสนามหญ้า A ไป D โดยตรง:</b> ระยะทางและการกระจัดเท่ากัน คือประมาณ 70.7 เมตร" },
            5: { path: [locations.A, locations.B, locations.C, locations.D, locations.E, locations.A], desc: "<b>เดินรอบบล็อกกลับมา A:</b><br>ระยะทาง = 200 เมตร <br>การกระจัด = 0 เมตร! เพราะกลับมาจุดเดิม" }
        };

        function getScreenX(gridX) { return originX + gridX * gridSize; }
        function getScreenY(gridY) { return originY - gridY * gridSize; } 

        // --- ระบบนำทาง Tabs ---
        function switchTab(tab) {
            activeTab = tab;
            ['demo', 'draw', 'quiz'].forEach(t => {
                document.getElementById(`tab-${t}`).classList.remove('active', 'bg-white');
                document.getElementById(`panel-${t}`).classList.add('hidden');
            });
            const activeBtn = document.getElementById(`tab-${tab}`);
            activeBtn.classList.add('active', 'bg-white');
            if(tab === 'quiz') activeBtn.classList.remove('bg-amber-50/30'); 
            
            document.getElementById(`panel-${tab}`).classList.remove('hidden');
            
            stopAnimation();
            if(tab === 'demo') {
                document.getElementById('visual-legend').style.display = 'block';
                playScenario(1);
            } else if (tab === 'draw') {
                document.getElementById('visual-legend').style.display = 'block';
                resetDrawing();
            } else if (tab === 'quiz') {
                document.getElementById('visual-legend').style.display = 'none';
                drawSimulationMap();
            }
        }

        // --- ระบบวาด Canvas ---
        function drawSimulationMap() {
            ctx.clearRect(0, 0, canvas.width, canvas.height);
            // กริด
            ctx.strokeStyle = '#e2e8f0'; ctx.lineWidth = 1; ctx.setLineDash([4, 4]);
            for (let x = originX - 3 * gridSize; x <= canvas.width; x += gridSize) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(x, canvas.height); ctx.stroke(); }
            for (let y = originY + 2 * gridSize; y >= 0; y -= gridSize) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(canvas.width, y); ctx.stroke(); }
            ctx.setLineDash([]);
            // เข็มทิศ
            drawCompassSymbol(60, 60);
            // ถนน
            ctx.fillStyle = '#64748b'; const roadThick = 40;
            ctx.fillRect(getScreenX(0) - roadThick/2, getScreenY(0) - roadThick/2, 6 * gridSize, roadThick);
            ctx.fillRect(getScreenX(0) - roadThick/2, getScreenY(5) - roadThick/2, 6 * gridSize, roadThick);
            ctx.fillRect(getScreenX(0) - roadThick/2, getScreenY(5) - roadThick/2, roadThick, 5 * gridSize + roadThick);
            ctx.fillRect(getScreenX(5) - roadThick/2, getScreenY(5) - roadThick/2, roadThick, 5 * gridSize + roadThick);
            // ทางม้าลาย
            ctx.fillStyle = '#ffffff';
            for (let i = 0; i < 6; i++) {
                ctx.fillRect(getScreenX(0) + 18, getScreenY(5) + (i * 7) - 18, 15, 3.5);
                ctx.fillRect(getScreenX(0) + (i * 7) - 18, getScreenY(5) + 18, 3.5, 15);
            }
            // สนามหญ้า
            ctx.fillStyle = '#a3e635'; 
            ctx.fillRect(getScreenX(0) + roadThick/2, getScreenY(5) + roadThick/2, 5 * gridSize - roadThick, 5 * gridSize - roadThick);
            ctx.fillStyle = '#14532d'; ctx.font = 'bold 20px Sarabun'; ctx.textAlign = 'center'; ctx.fillText('สนามหญ้า', getScreenX(2.5), getScreenY(2.2));
            // จุด Landmark
            Object.values(locations).forEach(pt => {
                const px = getScreenX(pt.x), py = getScreenY(pt.y);
                ctx.fillStyle = '#dc2626'; ctx.beginPath(); ctx.arc(px, py, 6, 0, Math.PI * 2); ctx.fill();
                ctx.fillStyle = '#1e293b'; ctx.font = 'bold 18px Arial'; ctx.textAlign = 'center'; ctx.fillText(pt.label, px, py + 24);
                ctx.font = '26px Arial';
                let offset = { x: 0, y: -16 };
                if (pt.label === 'A') offset = { x: -32, y: 10 };
                if (pt.label === 'C') offset = { x: 34, y: 10 };
                if (pt.label === 'D') offset = { x: 38, y: -16 };
                if (pt.label === 'E') offset = { x: -28, y: -18 };
                ctx.fillText(pt.emoji, px + offset.x, py + offset.y);
            });
        }

        function drawCompassSymbol(cx, cy) {
            ctx.strokeStyle = '#475569'; ctx.lineWidth = 1.5; ctx.beginPath(); ctx.arc(cx, cy, 24, 0, Math.PI * 2); ctx.stroke();
            ctx.beginPath(); ctx.moveTo(cx, cy - 28); ctx.lineTo(cx, cy + 28); ctx.moveTo(cx - 28, cy); ctx.lineTo(cx + 28, cy); ctx.stroke();
            ctx.fillStyle = '#1e293b'; ctx.font = 'bold 11px Arial'; ctx.textAlign = 'center';
            ctx.fillText('N', cx, cy - 30); ctx.fillText('S', cx, cy + 38); ctx.fillText('E', cx + 36, cy + 4); ctx.fillText('W', cx - 36, cy + 4);
        }

        function drawVectorArrow(fromX, fromY, toX, toY, color) {
            const dx = toX - fromX, dy = toY - fromY;
            if (Math.hypot(dx, dy) < 5) return; 
            const angle = Math.atan2(dy, dx), headlen = 14; 
            ctx.save(); ctx.beginPath(); ctx.moveTo(toX, toY);
            ctx.lineTo(toX - headlen * Math.cos(angle - Math.PI / 6), toY - headlen * Math.sin(angle - Math.PI / 6));
            ctx.lineTo(toX - headlen * Math.cos(angle + Math.PI / 6), toY - headlen * Math.sin(angle + Math.PI / 6));
            ctx.closePath(); ctx.fillStyle = color; ctx.fill(); ctx.restore();
        }

        // --- โหมด Demo ---
        function setPlaySpeed(speed) {
            playbackSpeed = speed;
            document.querySelectorAll('.speed-btn').forEach(btn => btn.className = "speed-btn py-1 text-xs border rounded-lg font-bold bg-white text-gray-700");
            document.getElementById(`speed-${speed}`).className = "speed-btn py-1 text-xs border border-blue-600 rounded-lg font-bold bg-blue-600 text-white shadow-sm";
        }

        function stopAnimation() { if(animFrameId) { cancelAnimationFrame(animFrameId); animFrameId = null; } }

        function playScenario(id) {
            stopAnimation();
            document.querySelectorAll('.scen-btn').forEach(btn => btn.className = "scen-btn text-left px-4 py-2 border rounded-lg text-sm hover:bg-blue-50 transition bg-white");
            document.getElementById(`btn-scen-${id}`).className = "scen-btn text-left px-4 py-2 border rounded-lg text-sm transition bg-blue-600 text-white font-semibold";
            const sc = scenarios[id];
            animProgress = 0; animSegments = []; animTotalUnits = 0;
            for (let i = 0; i < sc.path.length - 1; i++) {
                const dist = Math.hypot(sc.path[i+1].x - sc.path[i].x, sc.path[i+1].y - sc.path[i].y);
                animSegments.push({ p1: sc.path[i], p2: sc.path[i+1], length: dist, startUnit: animTotalUnits, endUnit: animTotalUnits + dist });
                animTotalUnits += dist;
            }
            document.getElementById('analysis-box').innerHTML = sc.desc;
            animateDemo();
        }

        function animateDemo() {
            animProgress += 0.012 * playbackSpeed; 
            if (animProgress > 1) animProgress = 1;
            drawSimulationMap();
            
            const currentUnits = animProgress * animTotalUnits;
            let cx = locations.A.x, cy = locations.A.y;

            // วาดเส้นระยะทาง
            ctx.beginPath(); ctx.moveTo(getScreenX(locations.A.x), getScreenY(locations.A.y));
            ctx.strokeStyle = '#2563eb'; ctx.lineWidth = 5; ctx.lineCap = 'round'; ctx.lineJoin = 'round';
            for (let seg of animSegments) {
                if (currentUnits >= seg.endUnit) {
                    ctx.lineTo(getScreenX(seg.p2.x), getScreenY(seg.p2.y)); cx = seg.p2.x; cy = seg.p2.y;
                } else if (currentUnits > seg.startUnit) {
                    const ratio = (currentUnits - seg.startUnit) / seg.length;
                    cx = seg.p1.x + (seg.p2.x - seg.p1.x) * ratio; cy = seg.p1.y + (seg.p2.y - seg.p1.y) * ratio;
                    ctx.lineTo(getScreenX(cx), getScreenY(cy)); break;
                }
            }
            ctx.stroke();

            // วาดการกระจัด
            ctx.beginPath(); ctx.moveTo(getScreenX(locations.A.x), getScreenY(locations.A.y)); ctx.lineTo(getScreenX(cx), getScreenY(cy));
            ctx.strokeStyle = '#dc2626'; ctx.lineWidth = 2.5; ctx.setLineDash([6, 5]); ctx.stroke(); ctx.setLineDash([]);
            drawVectorArrow(getScreenX(locations.A.x), getScreenY(locations.A.y), getScreenX(cx), getScreenY(cy), '#dc2626');

            // วาดตัวกิตติ
            ctx.fillStyle = '#f59e0b'; ctx.strokeStyle = '#fff'; ctx.lineWidth = 2; ctx.beginPath();
            ctx.arc(getScreenX(cx), getScreenY(cy), 9, 0, Math.PI * 2); ctx.fill(); ctx.stroke();

            // แสดงตัวเลข
            document.getElementById('dist-display').innerHTML = `${(currentUnits * scaleMeters).toFixed(1)} <span class="text-xs font-normal">ม.</span>`;
            document.getElementById('disp-display').innerHTML = `${(Math.hypot(cx - locations.A.x, cy - locations.A.y) * scaleMeters).toFixed(1)} <span class="text-xs font-normal">ม.</span>`;

            if (animProgress < 1) animFrameId = requestAnimationFrame(animateDemo);
        }

